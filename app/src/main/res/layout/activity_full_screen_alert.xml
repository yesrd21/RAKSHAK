<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_high_risk_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Top pulsing warning icon -->
        <TextView
            android:id="@+id/tvWarningIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨"
            android:textSize="72sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <!-- Main status: FRAUD DETECTED or CALL TERMINATED -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_fraud_detected"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <!-- Sub-status line -->
        <TextView
            android:id="@+id/tvSubStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_hang_up_now"
            android:textColor="#FFCDD2"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#55FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- Caller number card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#CC000000"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCaller"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <!-- Risk score -->
                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FF8A80"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <!-- Risk bar -->
                <TextView
                    android:id="@+id/tvRiskBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_high_risk"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <!-- Reason -->
                <TextView
                    android:id="@+id/tvReasonLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_reason"
                    android:textColor="#FFCDD2"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Safety instructions card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#AA000000"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_never_share"
                    android:textColor="#FF8A80"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_hang_up_call_back"
                    android:textColor="#FF8A80"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_report_1930"
                    android:textColor="#FFCDD2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- HANG UP button — big red -->
        <Button
            android:id="@+id/btnHangUp"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/btn_hang_up"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/color_high_risk"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Report button -->
        <Button
            android:id="@+id/btnReport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_report_cybercrime"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#880000CC"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Dismiss -->
        <Button
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_dismiss"
            android:textSize="13sp"
            android:textColor="#FFCDD2"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>

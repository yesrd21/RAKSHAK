<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/color_high_risk_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_high_risk_gradient"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 REGISTER FRAUD"
                    android:textColor="@color/color_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help protect the community"
                    android:textColor="#FFCDD2"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Community notice -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_surface_elevated">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="☁️ Reports are shared securely with all Rakshak AI users via Firebase to protect everyone from fraud."
                android:textColor="@color/color_accent"
                android:textSize="12sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/color_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◈ WHAT ARE YOU REPORTING?"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_accent"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupSourceType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 SMS Sender"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:checked="true"
                        android:textColor="@color/color_text_primary"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 Call Number"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:textColor="@color/color_text_primary"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️ Email"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSourceNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone / Call Number"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp"
                    app:boxStrokeColor="@color/color_card_border"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSourceNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvOrDivider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— or —"
                    android:textColor="@color/color_text_dim"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSourceEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Source Email Address"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp"
                    app:boxStrokeColor="@color/color_card_border"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSourceEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFraudMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Fraud Message Content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp"
                    app:boxStrokeColor="@color/color_card_border"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFraudMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="4"
                        android:gravity="top"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCallDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Describe the scam call (optional)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:boxStrokeColor="@color/color_card_border"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCallDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:gravity="top"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Fraud Category"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/color_card_border"
                    app:hintTextColor="@color/color_text_secondary">
                    <AutoCompleteTextView
                        android:id="@+id/actvCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="none"
                        android:textColor="@color/color_text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/progressSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚡ SUBMIT FRAUD REPORT"
                    app:backgroundTint="@color/color_high_risk_dark"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Header card with filter tabs -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 Message History"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvActiveFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Showing: All scanned messages"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"/>

            <!-- 4 filter tabs — tap to filter list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- ALL -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFilterAll"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/color_accent_dim"
                    app:cardCornerRadius="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvFilterTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALL"
                            android:textColor="#B3FFFFFF"
                            android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- HIGH RISK -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFilterHighRisk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/color_high_risk_dark"
                    app:cardCornerRadius="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvFilterHighRisk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚨 HIGH"
                            android:textColor="#FFCDD2"
                            android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- SUSPICIOUS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFilterSuspicious"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/color_suspicious_dark"
                    app:cardCornerRadius="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvFilterSuspicious"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️ SUSP"
                            android:textColor="#FFE0B2"
                            android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- SAFE -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFilterSafe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/color_safe_dark"
                    app:cardCornerRadius="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvFilterSafe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ SAFE"
                            android:textColor="#C8E6C9"
                            android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- List label + clear button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvListLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All Messages"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearSmsLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptySmsLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📭 No messages scanned yet.\n\nEvery SMS you receive will be automatically scanned and appear here with its risk score."
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:padding="40dp"
        android:lineSpacingExtra="4dp"
        android:visibility="gone"/>

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSmsLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
